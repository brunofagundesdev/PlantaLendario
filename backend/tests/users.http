### =========================
### GET /users
### Lista usuários
### =========================
GET http://localhost:3333/users
Content-Type: application/json
Authorization: Bearer {{bruninToken}}



### =========================
### GET /users/:id
### Usuário existente
### =========================
GET http://localhost:3333/users/{{bruninId}}
Content-Type: application/json
Authorization: Bearer {{bruninToken}}
###
GET http://localhost:3333/users/{{madonoId}}
Content-Type: application/json
Authorization: Bearer {{bruninToken}}



### =========================
### GET /users/:id
### ID inválido
### =========================
GET http://localhost:3333/users/123
Content-Type: application/json
Authorization: Bearer {{bruninToken}}



### =========================
### POST /users
### Criar usuário
### =========================
POST http://localhost:3333/users
Content-Type: application/json
Authorization: Bearer {{bruninToken}}

{
  "name": "Alissong",
  "email": "alisson@gmail.com",
  "password": "iwehriowberwoirhwbeorih"
}



