@baseUrl = http://localhost:3333
@roleId = d69f9dde-b0bd-4315-964f-8015c817eb3f

### =========================
### GET /roles
### Lista todas as roles
### =========================
GET {{baseUrl}}/roles
Content-Type: application/json


### =========================
### GET /roles/:id
### Role existente
### =========================
GET {{baseUrl}}/roles/{{roleId}}
Content-Type: application/json


### =========================
### GET /roles/:id
### ID inválido (espera erro)
### =========================
GET {{baseUrl}}/roles/123
Content-Type: application/json


### =========================
### POST /roles
### Criar role válida
### =========================
POST {{baseUrl}}/roles
Content-Type: application/json

{
  "name": "Planta",
  "color": "#79B822"
}


### =========================
### POST /roles
### Nome duplicado (espera erro)
### =========================
POST {{baseUrl}}/roles
Content-Type: application/json

{
  "name": "Admin"
}


### =========================
### POST /roles
### Body vazio (espera erro)
### =========================
POST {{baseUrl}}/roles
Content-Type: application/json

{}


### =========================
### POST /roles
### Campo inválido (espera erro)
### =========================
POST {{baseUrl}}/roles
Content-Type: application/json

{
  "name": 123
}


### =========================
### PUT /roles/:id
### Atualiza role (completo)
### =========================
PUT {{baseUrl}}/roles/{{roleId}}
Content-Type: application/json

{
  "name": "Plantaralho",
  "color": "#1e38bd"
}


### =========================
### PUT /roles/:id
### Body incompleto (espera erro)
### =========================
PUT {{baseUrl}}/roles/{{roleId}}
Content-Type: application/json

{}


### =========================
### PATCH /roles/:id
### Atualiza apenas o nome
### =========================
PATCH {{baseUrl}}/roles/{{roleId}}
Content-Type: application/json

{
  "name": "Planta",
  "color": "#79B822"
}


### =========================
### PATCH /roles/:id
### Body vazio (espera erro)
### =========================
PATCH {{baseUrl}}/roles/{{roleId}}
Content-Type: application/json

{}


### =========================
### DELETE /roles/:id
### Remove role existente
### =========================
DELETE {{baseUrl}}/roles/{{roleId}}
Content-Type: application/json


### =========================
### DELETE /roles/:id
### Role inexistente (espera erro)
### =========================
DELETE {{baseUrl}}/roles/00000000-0000-0000-0000-000000000000
Content-Type: application/json
