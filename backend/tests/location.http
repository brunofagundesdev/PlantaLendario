### =========================
### GET /locations
### Lista todas as locations
### =========================
GET {{baseUrl}}/locations
Content-Type: application/json
Authorization: Bearer {{bruninToken}}


### =========================
### GET /locations/:id
### Role existente
### =========================
GET {{baseUrl}}/locations/{{roleId}}
Content-Type: application/json
Authorization: Bearer {{bruninToken}}



### =========================
### GET /locations/:id
### ID inválido (espera erro)
### =========================
GET {{baseUrl}}/locations/123
Content-Type: application/json
Authorization: Bearer {{bruninToken}}



### =========================
### POST /locations
### Criar role válida
### =========================
POST {{baseUrl}}/locations
Content-Type: application/json
Authorization: Bearer {{bruninToken}}

{
  "name": "SALA   404  ",
  "type": "room"
}


### =========================
### POST /locations
### Nome duplicado (espera erro)
### =========================
POST {{baseUrl}}/locations
Content-Type: application/json
Authorization: Bearer {{bruninToken}}

{
  "name": "escriba",
  "color": "#0f2f76"
}


### =========================
### POST /locations
### Body vazio (espera erro)
### =========================
POST {{baseUrl}}/locations
Content-Type: application/json
Authorization: Bearer {{bruninToken}}

{}


### =========================
### POST /locations
### Campo inválido (espera erro)
### =========================
POST {{baseUrl}}/locations
Content-Type: application/json
Authorization: Bearer {{bruninToken}}

{
  "name": 123
}


### =========================
### PUT /locations/:id
### Atualiza role (completo)
### =========================
PUT {{baseUrl}}/locations/{{roleId}}
Content-Type: application/json

{
  "name": "Plantaralho",
  "color": "#1e38bd"
}


### =========================
### PUT /locations/:id
### Body incompleto (espera erro)
### =========================
PUT {{baseUrl}}/locations/{{roleId}}
Content-Type: application/json

{}


### =========================
### PATCH /locations/:id
### Atualiza apenas o nome
### =========================
PATCH {{baseUrl}}/locations/{{roleId}}
Content-Type: application/json

{
  "name": "Planta",
  "color": "#79B822"
}


### =========================
### PATCH /locations/:id
### Body vazio (espera erro)
### =========================
PATCH {{baseUrl}}/locations/{{roleId}}
Content-Type: application/json

{}


### =========================
### DELETE /locations/:id
### Remove role existente
### =========================
DELETE {{baseUrl}}/locations/{{roleId}}


### =========================
### DELETE /locations/:id
### Role inexistente (espera erro)
### =========================
DELETE {{baseUrl}}/locations/00000000-0000-0000-0000-000000000000
